{{ 'section-hero.css' | asset_url | stylesheet_tag }}

<section class="bkfk-hero-block">
  <div class="bkfk-container">
    <div class="bkfk-row">
      <div class="bkfk-col">
        <img
          class="vector-1"
          src="{{ 'hero-card-shape.svg' | asset_url }}"
          alt="">
        <img
          class="kokies"
          src="{{ 'hero-kokies.png' | asset_url }}"
          alt="">
        <span class="bkfk-tag-label">{{ section.settings.tag_label }}</span>
        <h1>{{ section.settings.heading }}</h1>
        <p>{{ section.settings.description }}</p>
        <div class="bkfk-btn">
          <a class="btn" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label }}
            <img src="{{ 'right-arrow.svg' | asset_url }}" alt="">
          </a>
          <label>{{ section.settings.helper_label }}</label>
        </div>
        <div class="bkfk-trusted">
          <p>
            <b>{{ section.settings.trusted_strong }}</b>
            {{ section.settings.trusted_suffix }}</p>
          <div class="logos">
            <img src="{{ 'stars.svg' | asset_url }}" alt="">
            <img src="{{ 'shopper-approved.svg' | asset_url }}" alt="">
          </div>
        </div>
      </div>
      <div class="bkfk-col">
        <div class="img-frame">
          {% if section.settings.hero_image != blank %}
            {{ section.settings.hero_image | image_url: width: 1800 | image_tag: loading: 'lazy' }}
          {% else %}
            <img src="{{ 'hero-img.png' | asset_url }}" alt="">
          {% endif %}
        </div>
      </div>
    </div>
    <img
      class="vector-2"
      src="{{ 'hero-card-shape2.svg' | asset_url }}"
      alt="">
  </div>
</section>

{% schema %}
  {
    "name": "Hero",
    "settings": [
      {
        "type": "text",
        "id": "tag_label",
        "label": "Tag label",
        "default": "Learning Made Simple"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Baking For Every Ability"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "A structured baking program to support children with disabilities through hands-on learning and confidence."
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Explore Programs"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      }, {
        "type": "text",
        "id": "helper_label",
        "label": "Helper text",
        "default": "Get started in minutes"
      }, {
        "type": "text",
        "id": "trusted_strong",
        "label": "Trusted bold text",
        "default": "Trusted"
      }, {
        "type": "text",
        "id": "trusted_suffix",
        "label": "Trusted suffix text",
        "default": "by 17,000+ parents"
      }, {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Hero image"
      }
    ],
    "presets": [
      {
        "name": "Hero"
      }
    ]
  }
{% endschema %}
